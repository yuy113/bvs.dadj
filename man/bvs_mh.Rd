\deqn{tau_k | sigma^2 \sim N(tau0, htau * sigma^2)}
\deqn{P(gamma | eta, R) propto exp(mu sum(gamma_j) + eta sum_{R} gamma_j gamma_k)}

where R is the adjacency matrix from the chosen \code{adj_type}.
